# =============================================================
# MiroFish-Offline 配置文件示例
# =============================================================
# 使用方法：
#   1) 复制本文件为 .env       ——  cp .env.example .env
#   2) 把下面带 <...> 的值替换成你自己的
#   3) .env 已被 .gitignore 忽略，不会上传，可放心填真实密钥
#
# 本分支用 Neo4j 替代 Zep 存图谱，LLM / Embedding 走任意
# OpenAI 兼容接口（中转站、自建、官方均可），无需 Ollama。
# =============================================================


# ===== 应用端口 =====
# 后端 Flask 端口；前端通过 VITE_API_BASE_URL 找后端。
# 默认 5101，避免和原版 MiroFish(5001) 冲突。
FLASK_PORT=5101
VITE_API_BASE_URL=http://localhost:5101


# ===== 主 LLM 配置（OpenAI 兼容格式）=====
# 用于：本体生成、人设生成、模拟配置、报告生成、OASIS 智能体对话。
# 必须支持 chat completions 和 function calling（工具调用）。
# BASE_URL 一般要带 /v1 结尾。
LLM_API_KEY=<你的-LLM-API-KEY>
LLM_BASE_URL=https://你的中转站地址/v1
LLM_MODEL_NAME=<模型名，例如 gpt-5.4-mini>


# ===== Neo4j 图数据库（替代 Zep）=====
# 本机用 docker compose up -d neo4j 启动即可。
# 端口 7688/7475 是为了不和其他 Neo4j 实例冲突（见 docker-compose.yml）。
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish


# ===== Embedding 向量化配置 =====
# EMBEDDING_PROVIDER 三选一：
#   openai  -> 走 OpenAI 兼容 /v1/embeddings 接口（推荐，配下面三行）
#   ollama  -> 走本地 Ollama /api/embed
#   hash    -> 本地哈希兜底，不调任何接口（仅供无 embedding 时跑通流程，质量低）
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=<你的-EMBEDDING-API-KEY>
EMBEDDING_BASE_URL=https://你的embedding中转站地址/v1
EMBEDDING_MODEL=<embedding 模型名，例如 google/gemini-embedding-001>
# Neo4j 向量索引维度，必须和下方模型实际维度匹配或由程序裁剪到此值。
# 默认 768；改这个值需要清空旧图谱重建，否则维度不一致会检索失败。
EMBEDDING_DIMENSION=768


# ===== OASIS / CAMEL-AI 配置 =====
# CAMEL-AI 框架只认 OPENAI_API_KEY / OPENAI_API_BASE_URL 这两个名字，
# 通常和上面的主 LLM 填成同一套即可。
OPENAI_API_KEY=<同 LLM_API_KEY>
OPENAI_API_BASE_URL=https://你的中转站地址/v1
